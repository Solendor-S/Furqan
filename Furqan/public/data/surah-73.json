{"surah": 73, "name_en": "Al-Muzzammil", "name_ar": "المُزمل", "verses": [{"hafs_aya": 1, "warsh_aya": 1, "abuamr_aya": 1, "hafs": ["يَٰٓأَيُّهَا", "ٱلۡمُزَّمِّلُ"], "warsh": ["يَٰٓأَيُّهَا", "اَ۬لْمُزَّمِّلُ"], "abuamr": ["يَٰٓأَيُّهَا", "اَ۬لۡمُزَّمِّلُ"], "reading": [], "ortho": [1], "abuamr_only": [], "en": "O thou wrapped up in thy raiment", "wbw": [["O you", "yāayyuhā"], ["who wraps himself", "l-muzamilu"]]}, {"hafs_aya": 2, "warsh_aya": 1, "abuamr_aya": 2, "hafs": ["قُمِ", "ٱلَّيۡلَ", "إِلَّا", "قَلِيلٗا"], "warsh": ["قُمِ", "اِ۬ليْلَ", "إِلَّا", "قَلِيلاٗ"], "abuamr": ["قُمِ", "اِ۬لَّيۡلَ", "إِلَّا", "قَلِيلٗا"], "reading": [], "ortho": [1, 3], "abuamr_only": [], "en": "Keep vigil the night long, save a little", "wbw": [["Stand", "qumi"], ["(in) the night", "al-layla"], ["except", "illā"], ["a little", "qalīlan"]]}, {"hafs_aya": 3, "warsh_aya": 2, "abuamr_aya": 3, "hafs": ["نِّصۡفَهُۥٓ", "أَوِ", "ٱنقُصۡ", "مِنۡهُ", "قَلِيلًا"], "warsh": ["نِّصْفَهُۥٓ", "أَوُ", "اُ۟نقُصْ", "مِنْهُ", "قَلِيلاً"], "abuamr": ["نِّصۡفَهُۥٓ", "أَوُ", "اُ۟نقُصۡ", "مِنۡهُ", "قَلِيلًا"], "reading": [], "ortho": [0, 1, 2, 3, 4], "abuamr_only": [], "en": "A half thereof, or abate a little thereof", "wbw": [["Half of it", "niṣ'fahu"], ["or", "awi"], ["lessen", "unquṣ"], ["from it", "min'hu"], ["a little", "qalīlan"]]}, {"hafs_aya": 4, "warsh_aya": 3, "abuamr_aya": 4, "hafs": ["أَوۡ", "زِدۡ", "عَلَيۡهِ", "وَرَتِّلِ", "ٱلۡقُرۡءَانَ", "تَرۡتِيلًا"], "warsh": ["اَوْ", "زِدْ", "عَلَيْهِ", "وَرَتِّلِ", "اِ۬لْقُرْءَانَ", "تَرْتِيلاًۖ"], "abuamr": ["أَوۡ", "زِدۡ", "عَلَيۡهِۖ", "وَرَتِّلِ", "اِ۬لۡقُرۡءَانَ", "تَرۡتِيلًا"], "reading": [], "ortho": [0, 1, 2, 4, 5], "abuamr_only": [], "en": "Or add (a little) thereto - and chant the Qur'an in measure", "wbw": [["Or", "aw"], ["add", "zid"], ["to it", "ʿalayhi"], ["and recite", "warattili"], ["the Quran", "l-qur'āna"], ["(with) measured rhythmic recitation", "tartīlan"]]}, {"hafs_aya": 5, "warsh_aya": 4, "abuamr_aya": 5, "hafs": ["إِنَّا", "سَنُلۡقِي