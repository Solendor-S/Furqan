{"surah": 94, "name_en": "Ash-Sharḥ", "name_ar": "الشَّرح", "verses": [{"hafs_aya": 1, "warsh_aya": 1, "abuamr_aya": 1, "hafs": ["أَلَمۡ", "نَشۡرَحۡ", "لَكَ", "صَدۡرَكَ"], "warsh": ["اَلَمْ", "نَشْرَحْ", "لَكَ", "صَدْرَكَ"], "abuamr": ["أَلَمۡ", "نَشۡرَحۡ", "لَكَ", "صَدۡرَكَ"], "reading": [], "ortho": [0, 1, 3], "abuamr_only": [], "en": "Have We not caused thy bosom to dilate", "wbw": [["Have not", "alam"], ["We expanded", "nashraḥ"], ["for you", "laka"], ["your breast", "ṣadraka"]]}, {"hafs_aya": 2, "warsh_aya": 2, "abuamr_aya": 2, "hafs": ["وَوَضَعۡنَا", "عَنكَ", "وِزۡرَكَ"], "warsh": ["وَوَضَعْنَا", "عَنكَ", "وِزْرَكَ"], "abuamr": ["وَوَضَعۡنَا", "عَنكَ", "وِزۡرَكَ"], "reading": [], "ortho": [0, 2], "abuamr_only": [], "en": "And eased thee of the burden", "wbw": [["And We removed", "wawaḍaʿnā"], ["from you", "ʿanka"], ["your burden", "wiz'raka"]]}, {"hafs_aya": 3, "warsh_aya": 3, "abuamr_aya": 3, "hafs": ["ٱلَّذِيٓ", "أَنقَضَ", "ظَهۡرَكَ"], "warsh": ["اَ۬لذِےٓ", "أَنقَضَ", "ظَهْرَكَ"], "abuamr": ["اَ۬لَّذِيٓ", "أَنقَضَ", "ظَهۡرَكَ"], "reading": [], "ortho": [0, 2], "abuamr_only": [], "en": "Which weighed down thy back", "wbw": [["Which", "alladhī"], ["weighed upon", "anqaḍa"], ["your back", "ẓahraka"]]}, {"hafs_aya": 4, "warsh_aya": 4, "abuamr_aya": 4, "hafs": ["وَرَفَعۡنَا", "لَكَ", "ذِكۡرَكَ"], "warsh": ["وَرَفَعْنَا", "لَكَ", "ذِكْرَكَۖ"], "abuamr": ["وَرَفَعۡنَا", "لَكَ", "ذِكۡرَكَ"], "reading": [], "ortho": [0, 2], "abuamr_only": [], "en": "And exalted thy fame", "wbw": [["And We raised high", "warafaʿnā"], ["for you", "laka"], ["your reputation", "dhik'raka"]]}, {"hafs_aya": 5, "warsh_aya": 5, "abuamr_aya": 5, "hafs": ["فَإِنَّ", "مَعَ", "ٱلۡعُسۡرِ", "يُسۡرًا"], "warsh": ["فَإِنَّ", "مَعَ", "اَ۬لْعُسْرِ", "يُسْراً"], "abuamr": ["فَإِنَّ", "مَعَ", "اَ۬لۡعُسۡرِ", "يُسۡرًا"], "reading": [], "ortho": [2, 3], "abuamr_only": [], "en": "But lo! with hardship goeth ease", "wbw": [["So indeed", "fa-inna"], ["with", "maʿa"], ["the hardship", "l-ʿus'ri"], ["(is) ease", "yus'ran"]]}, {"hafs_aya": 6, "warsh_aya": 6, "abuamr_aya": 6, "hafs": ["إِنَّ", "مَعَ", "ٱلۡعُسۡرِ", "يُسۡرٗا"], "warsh": ["اِنَّ", "مَعَ", "اَ۬لْعُسْرِ", "يُسْراٗۖ"], "abuamr": ["إِنَّ", "مَعَ", "اَ۬لۡعُسۡرِ", "يُسۡرٗا"], "reading": [], "ortho": [0, 2, 3], "abuamr_only": [], "en": "Lo! with hardship goeth ease", "wbw": [["Indeed", "inna"], ["with", "maʿa"], ["the hardship", "l-ʿus'ri"], ["(is) ease", "yus'ran"]]}, {"hafs_aya": 7, "warsh_aya": 7, "abuamr_aya": 7, "hafs": ["فَإِذَا", "فَرَغۡتَ", "فَٱنصَبۡ"], "warsh": ["فَإِذَا", "فَرَغْتَ", "فَانصَبْ"], "abuamr": ["فَإِذَا", "فَرَغۡتَ", "فَاَنصَبۡ"], "reading": [], "ortho": [1, 2], "abuamr_only": [], "en": "So when thou art relieved, still toil", "wbw": [["So when", "fa-idhā"], ["you have finished", "faraghta"], ["then labor hard", "fa-inṣab"]]}, {"hafs_aya": 8, "warsh_aya": 8, "abuamr_aya": 8, "hafs": ["وَإِلَىٰ", "رَبِّكَ", "فَٱرۡغَب"], "warsh": ["وَإِلَىٰ", "رَبِّكَ", "فَارْغَبْۖ"], "abuamr": ["وَإِلَىٰ", "رَبِّكَ", "فَاَرۡغَب"], "reading": [], "ortho": [2], "abuamr_only": [], "en": "And strive to please thy Lord", "wbw": [["And to", "wa-ilā"], ["your Lord", "rabbika"], ["turn your attention", "fa-ir'ghab"]]}]}